VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Serve quiz media (images/audio) as short-lived signed URLs with opaque,
# unguessable file names instead of predictable public URLs. Leave off (unset)
# until the media has been renamed on Storage (scripts/rename-media.mjs) and
# MEDIA_SECRET is set on the server, then set to "true". See scripts/rename-media.mjs.
VITE_SIGNED_MEDIA=false

# Server-side only (used by api/*.js) - never prefix these with VITE_, or
# Vite would bundle them into client-side code.
STRIPE_SECRET_KEY=sk_test_your-secret-key
# From Stripe dashboard -> Developers -> Webhooks -> your endpoint -> Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# From Supabase dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Secret that derives the opaque, unguessable media file names (HMAC key). Used
# by api/media and the rename script - the two MUST use the same value. Any long
# random string; keep it secret and stable (rotating it renames every file).
MEDIA_SECRET=your-long-random-media-secret
# Groq API key - powers the AI evaluation of Expression écrite (chat) and
# Expression orale (Whisper transcription + chat). From
# https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key